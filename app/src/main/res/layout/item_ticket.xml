<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#FAFAFA">

        <ImageView
            android:id="@+id/imgTicketMovie"
            android:layout_width="80dp"
            android:layout_height="110dp"
            android:scaleType="centerCrop"
            android:background="#E0E0E0"
            android:src="@android:drawable/ic_menu_gallery" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tvTicketMovieTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tên Phim"
                android:textColor="#212121"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTicketTheater"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="CGV Vincom"
                android:textColor="#1565C0"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTicketTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="18:00 - 20/11"
                android:textColor="#757575" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="6dp"
                android:background="#E0E0E0"
                android:layerType="software" /> <TextView
                android:id="@+id/tvTicketSeats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ghế: A1, A2"
                android:textColor="#D32F2F"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">
                
                <TextViewandroid:id="@+id/tvTicketDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Đặt lúc: 10:00 15/11"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E"/>

                <TextView
                    android:id="@+id/tvTicketTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="200,000 đ"
                    android:textStyle="bold"
                    android:textColor="#212121"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>